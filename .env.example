# Copy this file to .env and fill in your values. Never commit .env.

# After changing public Supabase URL/key, trigger a full rebuild/redeploy so the client bundle picks them up.
# URL and keys must be for the same Supabase project where you ran migrations (`supabase db push` or Dashboard SQL); otherwise PostgREST may report missing columns (schema cache).

# Option A — Next/Vercel naming (either works with Option B):
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Option B — Supabase CLI-style (anon key only in SUPABASE_KEY; never use service_role here):
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-anon-key

# Server-only: privileged actions (orders, invites, password-reset email check). Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Server-only: optional secret for password-reset email fingerprints in rate limiting (defaults to SUPABASE_SERVICE_ROLE_KEY if unset).
# RATE_LIMIT_SECRET=long-random-string

# Server-only: monthly invoice cron endpoint secret.
CRON_SECRET=replace-with-long-random-secret

# Optional — automated invite reminder cron (`/api/cron/invite-reminders`). Defaults shown in code.
# INVITE_REMINDER_COOLDOWN_DAYS=7
# INVITE_REMINDER_MIN_USER_AGE_HOURS=48
# INVITE_REMINDER_MAX_PER_RUN=15

# Public origin (invite, reset links, `/api/client-error` origin check).
#
# There is NO field named NEXT_PUBLIC_SITE_URL in Supabase. You set two different places to the *same* public URL:
#   1) Hosting (Vercel, etc.): Environment Variable NEXT_PUBLIC_SITE_URL = https://your-deploy.example (no trailing slash)
#   2) Supabase Dashboard → Authentication → URL configuration:
#        Site URL = that same origin (e.g. https://your-deploy.example)
#        Redirect URLs = add https://your-deploy.example/auth/callback
#      Then redeploy the app so invite emails use the correct redirectTo from the server.
#
# Production / preview: set this on the host (e.g. Vercel → Environment Variables → Production) to your
# stable public URL. If it is missing on non-Vercel hosts, server actions fall back to 127.0.0.1 and
# invite links break; production builds block invites until NEXT_PUBLIC_SITE_URL is a non-loopback origin.
# Local dev:
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000
# Production example (uncomment and set for deployed env; not localhost):
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
