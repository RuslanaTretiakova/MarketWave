# Copy this file to .env and fill in your values. Never commit .env.

# After changing any NEXT_PUBLIC_* value, trigger a full rebuild/redeploy so the client bundle picks up the new values.
# Vercel: Project → Settings → Environment Variables — set the same keys for Production (and Preview if you use preview URLs). If these are empty at build time, the deployed app throws when creating the Supabase browser client.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only: privileged actions (orders, invites, password-reset email check). Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public origin (invite, reset links, canonical host). Mirror it in Supabase → Authentication → URL configuration (Site URL + Redirect URLs entry `https://YOUR_ORIGIN/auth/callback`; avoid mixing www vs apex).
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000
