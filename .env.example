# Copy this file to .env and fill in your values. Never commit .env.

# After changing public Supabase URL/key, trigger a full rebuild/redeploy so the client bundle picks them up.

# Option A — Next/Vercel naming (either works with Option B):
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Option B — Supabase CLI-style (anon key only in SUPABASE_KEY; never use service_role here):
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-anon-key

# Server-only: privileged actions (orders, invites, password-reset email check). Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Server-only: optional secret for password-reset email fingerprints in rate limiting (defaults to SUPABASE_SERVICE_ROLE_KEY if unset).
# RATE_LIMIT_SECRET=long-random-string

# Public origin (invite, reset links, `/api/client-error` origin check). Must match Supabase → Authentication → Site URL and Redirect URLs (`https://YOUR_ORIGIN/auth/callback`).
# Local dev:
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000
# Vercel Production / stable app URL for this project (set in Vercel → Settings → Environment Variables → Production; do not rely on VERCEL_URL alone — it changes per deployment):
# NEXT_PUBLIC_SITE_URL=https://linkbuilding-6tm6hzytr-ruslanatretiakovas-projects.vercel.app
