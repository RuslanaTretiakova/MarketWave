# Copy this file to .env and fill in your values. Never commit .env.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only: privileged actions (orders, invites, password-reset email check). Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public site URL for Supabase email links (invite, password reset). Must match an entry under Supabase Auth → Redirect URLs (include `https://YOUR_ORIGIN/auth/callback`).
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000
